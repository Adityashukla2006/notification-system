# Copy to .env and adjust. Every variable the server reads is listed here.
# Values without a default below are REQUIRED and the server refuses to boot
# without them.

# --- HTTP server ---
HTTP_ADDR=:8080
SHUTDOWN_GRACE=15s
LOG_LEVEL=info

# --- Postgres (source of truth) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app_password
POSTGRES_DBNAME=notifications
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10

# --- Redis (ephemeral coordination) ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- Worker (delivery loop) ---
# WORKER_ID names this worker's in-flight list in Redis and MUST be stable
# across restarts: a worker returning under a new id orphans the claims it left
# behind. Empty means "use the hostname".
WORKER_ID=
# How long a single blocking claim waits for work. Also the worst-case delay
# before the worker notices a shutdown signal.
WORKER_CLAIM_TIMEOUT=5s
# How often the worker sweeps the schedule for due notifications. Sets the
# granularity of scheduled delivery: something due at T is delivered in
# [T, T+PROMOTE_EVERY).
WORKER_PROMOTE_EVERY=1s
# Max notifications promoted per sweep, so a large backlog coming due at once
# drains in bounded batches.
WORKER_PROMOTE_LIMIT=100

# --- Retry backoff (base * 2^attempt, jittered, capped, then dead-lettered) ---
WORKER_RETRY_BASE=1s
WORKER_RETRY_MAX=5m

# --- Tests ---
# The store and queue tests skip unless these are set, so a plain `go test ./...`
# passes while silently exercising nothing against a real Postgres or Redis.
# Set both to actually test the persistence and queue layers.
#
# WARNING: the store tests apply every migration DOWN then UP, which DROPS the
# tables. TEST_DATABASE_URL must point at a disposable database — never at the
# one the app uses. Create one with: CREATE DATABASE notifications_test;
#
# TEST_DATABASE_URL=postgres://user:password@127.0.0.1:5432/notifications_test?sslmode=disable
# TEST_REDIS_ADDR=localhost:6379
